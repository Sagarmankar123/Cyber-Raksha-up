<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/v2RootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F6"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ═══ TOP BAR ═══ -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="CyberRaksha V2"
                android:textColor="#2D3436"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <!-- Mode Switch -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvModeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🟢 NORMAL MODE"
                    android:textColor="#1FAF8B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/turboSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:trackTint="#B400FF"
                    app:thumbTint="#FFFFFF"/>

            </LinearLayout>
        </RelativeLayout>

        <!-- ═══ TURBO VIDEO PLACEHOLDER ═══ -->
        <!-- Tu yahan VideoView ya ExoPlayer add karega Android Studio mein -->
        <FrameLayout
            android:id="@+id/turboVideoContainer"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="16dp"
            android:background="#0A0A0A"
            android:visibility="gone">

            <!-- VIDEO PLACEHOLDER — Replace with VideoView or ExoPlayer -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="[ Spider Web Animation Here ]"
                android:textColor="#B400FF"
                android:textSize="14sp"
                android:fontFamily="monospace"/>

            <!-- Console Output on top of video -->
            <TextView
                android:id="@+id/tvConsoleOutput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:background="#CC000000"
                android:fontFamily="monospace"
                android:padding="12dp"
                android:textColor="#00FF94"
                android:textSize="11sp"
                android:visibility="gone"/>

        </FrameLayout>

        <!-- ═══ THREAT METER ═══ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#0D1117">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="THREAT LEVEL"
                            android:textColor="#475569"
                            android:textSize="10sp"
                            android:letterSpacing="0.15"
                            android:textAllCaps="true"/>

                        <TextView
                            android:id="@+id/tvRiskLevel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SAFE"
                            android:textColor="#00FF94"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvRiskHindi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="सुरक्षित"
                            android:textColor="#475569"
                            android:textSize="13sp"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvThreatScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="#00FF94"
                        android:textSize="48sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>

                </LinearLayout>

                <!-- Live Threat Meter -->
                <ProgressBar
                    android:id="@+id/threatMeter"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:progress="0"
                    android:max="100"
                    android:progressTint="#00FF94"
                    android:progressBackgroundTint="#1A2030"/>

                <!-- Score legend -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SAFE"
                        android:textColor="#00FF94"
                        android:textSize="9sp"
                        android:gravity="start"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SUSPICIOUS"
                        android:textColor="#FFD600"
                        android:textSize="9sp"
                        android:gravity="center"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="HIGH RISK"
                        android:textColor="#FF005C"
                        android:textSize="9sp"
                        android:gravity="end"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══ BEHAVIORAL DNA ═══ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardBehavior"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🧬 Behavioral DNA Engine"
                        android:textColor="#2D3436"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="● ACTIVE"
                        android:textColor="#1FAF8B"
                        android:textSize="10sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Learns your normal behavior. Flags anomalies like unusual UPI IDs or late-night app installs."
                    android:textColor="#636E72"
                    android:textSize="12sp"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tvBehaviorSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="#1FAF8B"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:background="#F0FFF8"
                    android:padding="10dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══ COMMUNITY THREAT INTEL ═══ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCommunity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🌐 Community Threat Intel"
                        android:textColor="#2D3436"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="● CONNECTED"
                        android:textColor="#1FAF8B"
                        android:textSize="10sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="India fraud database — SHA-256 hashes only. Your data never leaves device."
                    android:textColor="#636E72"
                    android:textSize="12sp"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tvCommunityStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="#1FAF8B"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:background="#F0FFF8"
                    android:padding="10dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══ ANDROID GUARDIAN ═══ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardGuardian"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡 Android Guardian System"
                    android:textColor="#2D3436"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Accessibility Service monitors banking apps in real time."
                    android:textColor="#636E72"
                    android:textSize="12sp"
                    android:layout_marginBottom="10dp"/>

                <!-- Protected Apps -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PhonePe" android:background="#EEF2FF"
                        android:textColor="#4338CA" android:textSize="11sp"
                        android:padding="6dp" android:layout_marginEnd="6dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="GPay" android:background="#EEF2FF"
                        android:textColor="#4338CA" android:textSize="11sp"
                        android:padding="6dp" android:layout_marginEnd="6dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Paytm" android:background="#EEF2FF"
                        android:textColor="#4338CA" android:textSize="11sp"
                        android:padding="6dp" android:layout_marginEnd="6dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SBI" android:background="#EEF2FF"
                        android:textColor="#4338CA" android:textSize="11sp"
                        android:padding="6dp" android:layout_marginEnd="6dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="HDFC" android:background="#EEF2FF"
                        android:textColor="#4338CA" android:textSize="11sp"
                        android:padding="6dp"/>

                </LinearLayout>

                <!-- Detections list -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="10dp"
                    android:background="#FFF8F0"
                    android:padding="10dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✓ UPI Collect Request Detection"
                        android:textColor="#D97706" android:textSize="11sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✓ Overlay Attack Detection"
                        android:textColor="#D97706" android:textSize="11sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✓ AnyDesk / TeamViewer Scam Detection"
                        android:textColor="#D97706" android:textSize="11sp"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══ RESPONSE ENGINE ═══ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚨 Response Engine"
                    android:textColor="#2D3436"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvEvidenceCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Evidence logs: 0"
                    android:textColor="#636E72"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReportFraud"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="🚩 Report Fraud"
                        android:textSize="13sp"
                        app:backgroundTint="#FF005C"
                        app:cornerRadius="12dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearEvidence"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Clear Log"
                        android:textSize="13sp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="#E0E0E0"
                        app:cornerRadius="12dp"
                        android:textColor="#636E72"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══ COMING SOON ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UPCOMING MODULES"
            android:textColor="#636E72"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.12"
            android:layout_marginBottom="10dp"
            android:layout_marginStart="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📷 QR Scanner" android:background="#F1F5F9"
                android:textColor="#475569" android:textSize="11sp"
                android:padding="8dp" android:layout_marginEnd="8dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💬 OTP Guard" android:background="#F1F5F9"
                android:textColor="#475569" android:textSize="11sp"
                android:padding="8dp" android:layout_marginEnd="8dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📩 SMS Analyzer" android:background="#F1F5F9"
                android:textColor="#475569" android:textSize="11sp"
                android:padding="8dp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
