<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor"
    android:fitsSystemWindows="true"
    tools:context=".PanicModeActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/panicToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="CYBERRAKSHA EMERGENCY SHIELD"
            app:titleCentered="true"
            app:titleTextAppearance="@style/ToolbarTitleBold"
            app:titleTextColor="@color/status_danger"
            app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
            app:navigationIconTint="@color/status_danger" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- STAGE 1: LOCKDOWN VIEW -->
            <LinearLayout
                android:id="@+id/lockdownContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="24dp"
                    app:cardBackgroundColor="@color/status_danger"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:src="@android:drawable/ic_dialog_alert"
                            android:backgroundTint="@color/white"
                            android:tint="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/panic_shield_title"
                            android:textColor="@color/white"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginTop="16dp" />

                        <TextView
                            android:id="@+id/tvLockdownStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Initializing Emergency Shield..."
                            android:textColor="@color/white"
                            android:alpha="0.9"
                            android:textSize="14sp"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardLockdownChecks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="@color/surface_white">

                    <LinearLayout
                        android:id="@+id/lockdownChecksList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:id="@+id/lockdownActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="20dp"
                    android:visibility="gone">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnKillNetwork"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="⚡ KILL NETWORK NOW"
                        app:backgroundTint="@color/status_danger"
                        app:cornerRadius="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnViewSuspiciousApps"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:text="📋 VIEW SUSPICIOUS APPS"
                        app:cornerRadius="16dp"
                        style="@style/Widget.Material3.Button.TonalButton"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReviewApps"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:text="@string/btn_review_apps"
                        app:cornerRadius="16dp"
                        style="@style/Widget.Material3.Button.TonalButton"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnWifiSettings"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:text="@string/btn_wifi_settings"
                        app:cornerRadius="16dp"
                        style="@style/Widget.Material3.Button.TonalButton"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnContinueDiagnosis"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="16dp"
                        android:text="@string/btn_continue_diagnosis"
                        android:textColor="@color/backgroundColor"
                        app:backgroundTint="@color/primaryColor"
                        app:cornerRadius="16dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- STAGE 2: DIAGNOSIS VIEW -->
            <LinearLayout
                android:id="@+id/diagnosisContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/diagnosis_stage_title"
                    android:textColor="@color/primaryColor"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="16dp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardBackgroundColor="@color/surface_white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:id="@+id/tvDiagnosisPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textColor="@color/primaryColor"
                            android:textSize="32sp"
                            android:textStyle="bold" />

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/diagnosisProgress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            app:trackThickness="12dp"
                            app:trackCornerRadius="6dp"
                            app:indicatorColor="@color/primaryColor" />

                        <TextView
                            android:id="@+id/tvDiagnosisDetail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="@string/scan_status_apps"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- STAGE 3: SOLUTION VIEW -->
            <LinearLayout
                android:id="@+id/solutionContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/report_title"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="24dp"
                    app:cardBackgroundColor="@color/surface_white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/tvSecurityScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/security_score"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvFinalThreatLevel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/threat_level_label"
                            android:layout_marginTop="4dp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider_color"
                            android:layout_marginVertical="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/detected_issues_label"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/tvDetectedIssuesList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/text_secondary"
                            android:lineSpacingExtra="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- AI EXPLANATION -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="24dp"
                    app:cardBackgroundColor="#0DFFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/threat_explanation_title"
                            android:textColor="@color/primaryColor"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvAiExplainEn"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/threat_explain_en"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/tvAiExplainHi"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/threat_explain_hi"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- SOLUTIONS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/quick_solutions_label"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRemoveSusApps"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/btn_remove_apps"
                    android:layout_marginBottom="8dp"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResetPerms"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/btn_reset_perms"
                    android:layout_marginBottom="8dp"
                    app:cornerRadius="16dp"
                    style="@style/Widget.Material3.Button.TonalButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReportFraud"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="20dp"
                    android:text="@string/btn_report_cyber_fraud"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/status_danger"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_send" />

                <!-- FINAL GUIDANCE -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="40dp"
                    app:cardCornerRadius="24dp"
                    app:cardBackgroundColor="@color/primaryLightColor">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/final_guidance_title"
                            android:textColor="@color/primaryColor"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvFinalGuidance"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:textColor="@color/text_primary"
                            android:lineSpacingExtra="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
