<?xml version="1.0" encoding="utf-8"?>
<!--
    CyberRaksha Dynamic Island
    ══════════════════════════════════════════════════════════════════
    Matches the video reference exactly:

    IDLE PILL
    ┌─────────────────────────────┐
    │ ● 🛡 Guardian        │ 0%  │   ← small compact pill
    └─────────────────────────────┘

    MUSIC STATE (auto-expands, no tap needed)
    ┌──────────────────────────────────────┐
    │  🎵  Song Title                 ▶⏭  │   ← wider pill
    │       Artist · Spotify              │
    └──────────────────────────────────────┘

    MUSIC EXPANDED (tap)
    ┌──────────────────────────────────────┐
    │  ●●  Song Title                      │
    │      Artist                          │
    │  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━  │
    │   ⏮        ⏸/▶         ⏭          │
    └──────────────────────────────────────┘

    CALL STATE (incoming call)
    ┌──────────────────────────────────────┐
    │  📞  Caller Name            0:00    │
    │      Incoming · CyberRaksha check   │
    │  [✕ Decline]         [✓ Answer]    │
    └──────────────────────────────────────┘

    MESSAGE (WhatsApp/Telegram)
    ┌──────────────────────────────────────┐
    │  💬  Sender Name         WhatsApp   │
    │      Message preview text...        │
    └──────────────────────────────────────┘

    SECURITY ALERT (scam/UPI)
    ┌──────────────────────────────────────┐
    │  ⚠   SCAM CALL DETECTED     HIGH   │
    │      +91-XXXXXXXXXX                 │
    │  [Block]    [Accept]    [Report]    │
    └──────────────────────────────────────┘

    TURBO STATUS (manual tap on pill)
    ┌──────────────────────────────────────┐
    │  🕷  CyberRaksha TURBO               │
    │      Threat: 0% · All Clear         │
    │  [🟢 Normal]        [🕷 Turbo]     │
    └──────────────────────────────────────┘
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal">

    <!-- ══════════════════════════════════════════════════════════
         IDLE PILL
         Small compact capsule — always visible when idle
         ══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/pillContainer"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_dynamic_bar"
        android:gravity="center_vertical"
        android:minWidth="150dp"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:clickable="true"
        android:focusable="true">

        <View
            android:id="@+id/statusDot"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:layout_marginEnd="7dp"
            android:background="@drawable/dot_safe" />

        <TextView
            android:id="@+id/tvPillMode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:text="🛡 Guardian"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <View
            android:layout_width="1dp"
            android:layout_height="14dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/tvPillScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="0%"
            android:textColor="#00FF94"
            android:textSize="11sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════
         EXPANDED PANEL
         Morphs from the pill — all states live here
         ══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/panelContainer"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_island_panel"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:visibility="gone">

        <!-- ── Shared header: icon + title + subtitle + collapse ── -->
        <LinearLayout
            android:id="@+id/headerRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">

            <TextView
                android:id="@+id/tvPanelIcon"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:textSize="18sp"
                android:text="🛡"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPanelTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:text="CyberRaksha"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPanelSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:fontFamily="monospace"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:text="Guardian"
                    android:textColor="#88FFFFFF"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- Right side — changes per state -->
            <LinearLayout
                android:id="@+id/headerRight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Collapse arrow (always visible) -->
                <TextView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:gravity="center"
                    android:text="▼"
                    android:textColor="#33FFFFFF"
                    android:textSize="9sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ── Thin divider ────────────────────────────────────── -->
        <View
            android:id="@+id/dividerTop"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="#1AFFFFFF" />

        <!-- ══════════════════════════════════════════════════════
             MUSIC SECTION
             ══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/sectionMusic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Main row: art + info + play button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Album art circle -->
                <TextView
                    android:id="@+id/tvMusicArt"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_music_art"
                    android:gravity="center"
                    android:text="🎵"
                    android:textSize="22sp" />

                <!-- Song info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvMusicTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="marquee"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:singleLine="true"

                        android:text="Song Title"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="2dp">

                        <TextView
                            android:id="@+id/tvMusicArtist"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:singleLine="true"
                            android:text="Artist"
                            android:textColor="#99FFFFFF"
                            android:textSize="11sp" />

                        <View
                            android:layout_width="3dp"
                            android:layout_height="3dp"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="5dp"
                            android:background="@drawable/dot_safe"
                            android:alpha="0.5" />

                        <TextView
                            android:id="@+id/tvMusicApp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="YouTube"
                            android:textColor="#55FFFFFF"
                            android:textSize="10sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Play/Pause big button -->
                <TextView
                    android:id="@+id/btnMusicPlayPause"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_music_btn"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="⏸"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp" />

            </LinearLayout>

            <!-- Prev / Next row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:id="@+id/btnMusicPrev"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_mode_normal_inactive"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="⏮  Previous"
                    android:textColor="#AAFFFFFF"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/btnMusicNext"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_mode_normal_inactive"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="Next  ⏭"
                    android:textColor="#AAFFFFFF"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════
             CALL SECTION
             ══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/sectionCall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Caller row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Animated call circle -->
                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_call_circle"
                    android:gravity="center"
                    android:text="📞"
                    android:textSize="22sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvCallName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:ellipsize="end"
                        android:text="Unknown Caller"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCallStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Incoming Call"
                        android:textColor="#99FFFFFF"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvCallRisk"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="monospace"
                        android:text="🛡 Checking..."
                        android:textColor="#FFB800"
                        android:textSize="10sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Answer / Decline -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnCallDecline"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_danger"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="✕  Decline"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnCallAnswer"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_mode_normal_active"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="✓  Answer"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════
             MESSAGE SECTION
             ══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/sectionMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvMsgEmoji"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_mode_normal_inactive"
                android:gravity="center"
                android:text="💬"
                android:textSize="22sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvMsgSender"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:singleLine="true"
                        android:ellipsize="end"
                        android:text="Sender"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvMsgApp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_mode_normal_inactive"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:text="WhatsApp"
                        android:textColor="#AAFFFFFF"
                        android:textSize="9sp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvMsgPreview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="Message preview..."
                    android:textColor="#99FFFFFF"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════
             TIMER SECTION
             ══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/sectionTimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="⏱"
                android:textSize="28sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTimerValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="00:00"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTimerLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Timer"
                    android:textColor="#88FFFFFF"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════
             SECURITY SECTION (scam/UPI/overlay alerts)
             ══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/sectionSecurity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvPanelBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:lineSpacingExtra="3dp"
                android:text=""
                android:textColor="#CCFFFFFF"
                android:textSize="11sp" />

            <LinearLayout
                android:id="@+id/actionRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_horizontal"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/btnAction1"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_danger"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="Block"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/btnAction2"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_neutral"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="Accept"
                    android:textColor="#CCFFFFFF"
                    android:textSize="11sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/btnAction3"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_warn"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="Report"
                    android:textColor="#FFB800"
                    android:textSize="11sp"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════
             SCAN SECTION
             ══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/sectionScan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <ProgressBar
                android:id="@+id/scanProgress"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:progressTint="#00FF94"
                android:progressBackgroundTint="#22FFFFFF" />

            <TextView
                android:id="@+id/tvScanLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="monospace"
                android:text="0 / 42"
                android:textColor="#66FFFFFF"
                android:textSize="10sp" />

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════
             MODE TOGGLE (Normal ↔ Turbo)
             Always at bottom — user can hide via long-press score
             ══════════════════════════════════════════════════════ -->
        <View
            android:id="@+id/dividerMode"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="10dp"
            android:background="#1AFFFFFF" />

        <LinearLayout
            android:id="@+id/modeToggleRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnModeNormal"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_mode_normal_active"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="🟢  Normal"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnModeTurbo"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:background="@drawable/bg_mode_turbo_inactive"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="🕷  Turbo"
                android:textColor="#AAFFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Hide hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:text="Long-press score on dashboard to hide toggle"
            android:textColor="#1AFFFFFF"
            android:textSize="8sp" />

    </LinearLayout>

</FrameLayout>
