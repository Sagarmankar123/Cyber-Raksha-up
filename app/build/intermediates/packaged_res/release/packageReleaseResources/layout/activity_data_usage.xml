<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#F5F7F6">
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/dataToolbar"
            android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
            android:background="#1FAF8B" app:title="Data Usage Monitor"
            app:titleTextColor="#FFFFFF" app:navigationIcon="@drawable/ic_launcher_foreground"
            app:navigationIconTint="#FFFFFF"/>
    </com.google.android.material.appbar.AppBarLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_margin="16dp" app:cardCornerRadius="16dp" app:cardElevation="4dp"
            app:cardBackgroundColor="#0D1117">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <TextView android:id="@+id/tvPeriod"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tvTotalMobile"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📶 Mobile: Loading..." android:textColor="#00FF94"
                    android:textSize="18sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tvTotalWifi"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📡 WiFi: Loading..." android:textColor="#B400FF"
                    android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRefreshData"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp" android:text="🔄 Refresh Data Usage"
            app:backgroundTint="#1FAF8B"/>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDataUsage"
            android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1"/>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
