<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:clipToPadding="false"
    android:paddingBottom="80dp">

    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingTop="52dp" android:paddingBottom="20dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Intelligence Engine"
                android:textColor="#FFFFFF" android:textSize="24sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="CyberRaksha V2 Core Innovations"
                android:textColor="#B400FF" android:textSize="13sp" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- BEHAVIORAL DNA -->
        <androidx.cardview.widget.CardView android:id="@+id/cardBehaviorDna"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" app:cardCornerRadius="20dp" app:cardElevation="0dp"
            app:cardBackgroundColor="#0D1117">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🧬" android:textSize="28sp" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Behavioral DNA Engine"
                            android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="V2 Core Invention #1"
                            android:textColor="#00FF94" android:textSize="11sp"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvDnaStatus"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="● Active" android:textColor="#00FF94" android:textSize="11sp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Learns your digital behavior in 30 seconds. Detects anomalies like unusual app installs or unknown UPI requests."
                    android:textColor="#94A3B8" android:textSize="13sp" android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="12dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:background="#0A1628"
                    android:padding="10dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvDnaUpiCount"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="#00FF94" android:textSize="22sp"
                            android:textStyle="bold" android:fontFamily="monospace"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Known UPI IDs" android:textColor="#475569" android:textSize="10sp"/>
                    </LinearLayout>
                    <View android:layout_width="1dp" android:layout_height="40dp"
                        android:background="#1E293B"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvDnaAppCount"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="#00FF94" android:textSize="22sp"
                            android:textStyle="bold" android:fontFamily="monospace"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Known Apps" android:textColor="#475569" android:textSize="10sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- COMMUNITY INTEL -->
        <androidx.cardview.widget.CardView android:id="@+id/cardCommunityIntel"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" app:cardCornerRadius="20dp" app:cardElevation="0dp"
            app:cardBackgroundColor="#0D1117">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌐" android:textSize="28sp" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Community Threat Intelligence"
                            android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="V2 Core Invention #2"
                            android:textColor="#00BFFF" android:textSize="11sp"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvCommunityStatus"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="● Live" android:textColor="#00BFFF" android:textSize="11sp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Crowd-powered fraud protection. If one user reports fraud in Mumbai, users across India are protected instantly. Privacy: SHA-256 hashes only."
                    android:textColor="#94A3B8" android:textSize="13sp" android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="12dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:background="#0A1628" android:padding="10dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvCommThreatCount"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="61" android:textColor="#00BFFF" android:textSize="22sp"
                            android:textStyle="bold" android:fontFamily="monospace"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Total Threats" android:textColor="#475569" android:textSize="10sp"/>
                    </LinearLayout>
                    <View android:layout_width="1dp" android:layout_height="40dp" android:background="#1E293B"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="SHA-256" android:textColor="#00BFFF" android:textSize="16sp"
                            android:textStyle="bold" android:fontFamily="monospace"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Privacy Protected" android:textColor="#475569" android:textSize="10sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ANDROID GUARDIAN -->
        <androidx.cardview.widget.CardView android:id="@+id/cardAndroidGuardian"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" app:cardCornerRadius="20dp" app:cardElevation="0dp"
            app:cardBackgroundColor="#0D1117">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🛡" android:textSize="28sp" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Android Guardian System"
                            android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="V2 Core Invention #3"
                            android:textColor="#B400FF" android:textSize="11sp"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvGuardianStatus"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="● Watching" android:textColor="#B400FF" android:textSize="11sp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Real-time UPI fraud interception using Accessibility Service. Detects collect requests, overlay attacks, and AnyDesk scams."
                    android:textColor="#94A3B8" android:textSize="13sp" android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="12dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PhonePe" android:background="#1A0D1F" android:textColor="#B400FF"
                        android:textSize="11sp" android:padding="6dp" android:layout_marginEnd="6dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="GPay" android:background="#1A0D1F" android:textColor="#B400FF"
                        android:textSize="11sp" android:padding="6dp" android:layout_marginEnd="6dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Paytm" android:background="#1A0D1F" android:textColor="#B400FF"
                        android:textSize="11sp" android:padding="6dp" android:layout_marginEnd="6dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SBI" android:background="#1A0D1F" android:textColor="#B400FF"
                        android:textSize="11sp" android:padding="6dp" android:layout_marginEnd="6dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="HDFC" android:background="#1A0D1F" android:textColor="#B400FF"
                        android:textSize="11sp" android:padding="6dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- THREAT ENGINE -->
        <androidx.cardview.widget.CardView android:id="@+id/cardThreatEngine"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" app:cardCornerRadius="20dp" app:cardElevation="0dp"
            app:cardBackgroundColor="#0D1117">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⚡" android:textSize="28sp" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Threat Engine"
                            android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Central Risk Brain"
                            android:textColor="#FF005C" android:textSize="11sp"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvThreatScore"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0%" android:textColor="#00FF94" android:textSize="20sp"
                        android:textStyle="bold" android:fontFamily="monospace"/>
                </LinearLayout>
                <ProgressBar android:id="@+id/intelThreatMeter"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent" android:layout_height="8dp"
                    android:progress="0" android:max="100"
                    android:progressTint="#00FF94" android:progressBackgroundTint="#1E293B"
                    android:layout_marginBottom="12dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:background="#0A1628" android:padding="10dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="+40" android:textColor="#FF005C" android:textSize="16sp"
                            android:textStyle="bold" android:fontFamily="monospace"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Scam Call" android:textColor="#475569" android:textSize="10sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="+30" android:textColor="#FFD600" android:textSize="16sp"
                            android:textStyle="bold" android:fontFamily="monospace"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="UPI Collect" android:textColor="#475569" android:textSize="10sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="+20" android:textColor="#00BFFF" android:textSize="16sp"
                            android:textStyle="bold" android:fontFamily="monospace"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Unknown UPI" android:textColor="#475569" android:textSize="10sp"/>
                    </LinearLayout>
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReportFraud"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:layout_marginTop="12dp" android:text="🚩 Report Fraud"
                    android:textSize="13sp" app:backgroundTint="#FF005C" app:cornerRadius="12dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
