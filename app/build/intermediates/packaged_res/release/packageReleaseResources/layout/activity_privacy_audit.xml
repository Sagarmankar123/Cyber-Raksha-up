<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#F5F7F6">
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/privacyToolbar"
            android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
            android:background="#B400FF" app:title="Privacy Audit"
            app:titleTextColor="#FFFFFF" app:navigationIcon="@drawable/ic_launcher_foreground"
            app:navigationIconTint="#FFFFFF"/>
    </com.google.android.material.appbar.AppBarLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_margin="16dp" app:cardCornerRadius="16dp"
            app:cardElevation="4dp" app:cardBackgroundColor="#0D1117">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <TextView android:id="@+id/tvPrivacySummary"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔍 Scanning..." android:textColor="#AAAAAA" android:textSize="13sp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="8dp">
                    <TextView android:id="@+id/tvRiskCount"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="⚠️ Risk: 0"
                        android:textColor="#FF005C" android:textSize="16sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvSafeCount"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="✅ Safe: 0"
                        android:textColor="#00FF94" android:textSize="16sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/privacyTabLayout"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
            android:background="#FFFFFF" app:tabGravity="fill" app:tabMode="fixed"
            app:tabSelectedTextColor="#B400FF" app:tabTextColor="#636E72"
            app:tabIndicatorColor="#B400FF">
            <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="High Risk"/>
            <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Medium"/>
            <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Safe"/>
        </com.google.android.material.tabs.TabLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPrivacyApps"
            android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1"/>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
