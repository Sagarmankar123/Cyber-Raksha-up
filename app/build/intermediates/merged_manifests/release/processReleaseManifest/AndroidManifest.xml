<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.cyberraksha.guardian"
    android:versionCode="3"
    android:versionName="3.0" >

    <uses-sdk
        android:minSdkVersion="26"
        android:targetSdkVersion="35" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES" />

    <permission
        android:name="com.cyberraksha.guardian.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.cyberraksha.guardian.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:extractNativeLibs="false"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="CyberRaksha"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CyberRaksha" >
        <activity
            android:name="com.cyberraksha.guardian.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.App.Splash" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.cyberraksha.guardian.OnboardingActivity"
            android:exported="false" />
        <activity
            android:name="com.cyberraksha.guardian.MainActivity"
            android:exported="false" />
        <activity
            android:name="com.cyberraksha.guardian.IntelligenceActivity"
            android:exported="false"
            android:label="Intelligence Engine"
            android:parentActivityName="com.cyberraksha.guardian.MainActivity" />
        <activity
            android:name="com.cyberraksha.guardian.V2SecurityEngineActivity"
            android:exported="false"
            android:label="V2 Engine"
            android:parentActivityName="com.cyberraksha.guardian.MainActivity" />
        <activity
            android:name="com.cyberraksha.guardian.SpyDetectionActivity"
            android:exported="false"
            android:parentActivityName="com.cyberraksha.guardian.MainActivity" />
        <activity
            android:name="com.cyberraksha.guardian.AbuseCheckActivity"
            android:exported="false"
            android:parentActivityName="com.cyberraksha.guardian.MainActivity" />
        <activity
            android:name="com.cyberraksha.guardian.ChatbotActivity"
            android:exported="false"
            android:parentActivityName="com.cyberraksha.guardian.MainActivity"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name="com.cyberraksha.guardian.TrueNewsActivity"
            android:exported="false"
            android:parentActivityName="com.cyberraksha.guardian.MainActivity"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name="com.cyberraksha.guardian.AiNewsSelectionActivity"
            android:exported="false"
            android:parentActivityName="com.cyberraksha.guardian.MainActivity" />
        <activity
            android:name="com.cyberraksha.guardian.NewsDetectionActivity"
            android:exported="false"
            android:parentActivityName="com.cyberraksha.guardian.AiNewsSelectionActivity"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name="com.cyberraksha.guardian.ScanListActivity"
            android:exported="false"
            android:parentActivityName="com.cyberraksha.guardian.MainActivity" />
        <activity
            android:name="com.cyberraksha.guardian.NetworkSecurityActivity"
            android:exported="false"
            android:parentActivityName="com.cyberraksha.guardian.MainActivity" />
        <activity
            android:name="com.cyberraksha.guardian.SafeSearchActivity"
            android:exported="false"
            android:parentActivityName="com.cyberraksha.guardian.MainActivity" />
        <activity
            android:name="com.cyberraksha.guardian.PanicModeActivity"
            android:exported="false"
            android:label="Emergency Shield"
            android:parentActivityName="com.cyberraksha.guardian.MainActivity" />
        <activity
            android:name="com.cyberraksha.guardian.BatteryOptimizerActivity"
            android:exported="false"
            android:parentActivityName="com.cyberraksha.guardian.MainActivity" />
        <activity
            android:name="com.cyberraksha.guardian.DataUsageActivity"
            android:exported="false"
            android:parentActivityName="com.cyberraksha.guardian.MainActivity" />
        <activity
            android:name="com.cyberraksha.guardian.JunkCleanerActivity"
            android:exported="false"
            android:parentActivityName="com.cyberraksha.guardian.MainActivity" />
        <activity
            android:name="com.cyberraksha.guardian.PrivacyAuditActivity"
            android:exported="false"
            android:parentActivityName="com.cyberraksha.guardian.MainActivity" />

        <service
            android:name="com.cyberraksha.guardian.SafeSearchService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE" >
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>

            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Dynamic Control Bar Overlay Service -->
        <service
            android:name="com.cyberraksha.guardian.DynamicBarService"
            android:exported="false"
            android:foregroundServiceType="specialUse" >
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Shows CyberRaksha Dynamic Control Bar overlay for security protection." />
        </service>
        <service
            android:name="com.cyberraksha.guardian.CallDetectionService"
            android:exported="false"
            android:foregroundServiceType="specialUse" >
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Identifies spam calls to protect users from fraud." />
        </service>

        <!--
             Island Notification Listener — intercepts ALL system notifications
             Enables: music, calls, messages, timers, any app → Dynamic Island
             User grants: Settings → Notification Access → CyberRaksha
        -->
        <service
            android:name="com.cyberraksha.guardian.IslandNotificationService"
            android:exported="false"
            android:label="CyberRaksha Island Notifications"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE" >
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!--
             AppInstallReceiver — wires real PACKAGE_ADDED to BehaviorService
             This makes the Behavioral DNA Engine actually learn installed apps
        -->
        <receiver
            android:name="com.cyberraksha.guardian.AppInstallReceiver"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />

                <data android:scheme="package" />
            </intent-filter>
        </receiver>

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.cyberraksha.guardian.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>