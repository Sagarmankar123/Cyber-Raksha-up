<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />
    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- Deep Scan Permissions -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CyberRaksha">

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.App.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".OnboardingActivity" android:exported="false" />

        <activity
            android:name=".SpyDetectionActivity"
            android:label="Spy Detection"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".AbuseCheckActivity"
            android:label="Abuse Check"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <activity
            android:name=".ChatbotActivity"
            android:label="Security Assistant"
            android:parentActivityName=".MainActivity"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".TrueNewsActivity"
            android:label="True News AI"
            android:parentActivityName=".MainActivity"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".AiNewsSelectionActivity"
            android:label="AI &amp; News Detection"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".NewsDetectionActivity"
            android:label="News Verification"
            android:parentActivityName=".AiNewsSelectionActivity"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ScanListActivity"
            android:label="Security Scan"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".NetworkSecurityActivity"
            android:label="Network Security"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".BloatwareActivity"
            android:label="Bloatware Scanner"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".SafeSearchActivity"
            android:label="Safe Search"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".PanicModeActivity"
            android:label="Emergency Shield"
            android:parentActivityName=".MainActivity" />

        <service
            android:name=".SafeSearchService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <service
            android:name=".CallDetectionService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
            <property android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Call identification and spam protection during incoming calls to protect users from fraud." />
        </service>

    </application>

</manifest>
