<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" tools:ignore="QueryAllPackagesPermission"/>
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" tools:ignore="ProtectedPermissions"/>
    <uses-permission android:name="android.permission.READ_SMS"/>
    <uses-permission android:name="android.permission.RECEIVE_SMS"/>
    <uses-permission android:name="android.permission.READ_CALL_LOG"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE"/>
    <uses-permission android:name="android.permission.READ_PHONE_STATE"/>
    <uses-permission android:name="android.permission.READ_CONTACTS"/>
    <uses-permission android:name="android.permission.VIBRATE"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="CyberRaksha"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CyberRaksha">

        <activity android:name=".SplashActivity" android:exported="true"
            android:theme="@style/Theme.App.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity android:name=".OnboardingActivity" android:exported="false"/>
        <activity android:name=".MainActivity" android:exported="false"/>
        <activity android:name=".IntelligenceActivity" android:exported="false"
            android:label="Intelligence Engine" android:parentActivityName=".MainActivity"/>
        <activity android:name=".V2SecurityEngineActivity" android:exported="false"
            android:label="V2 Engine" android:parentActivityName=".MainActivity"/>
        <activity android:name=".SpyDetectionActivity" android:exported="false"
            android:parentActivityName=".MainActivity"/>
        <activity android:name=".AbuseCheckActivity" android:exported="false"
            android:parentActivityName=".MainActivity"/>
        <activity android:name=".ChatbotActivity" android:exported="false"
            android:parentActivityName=".MainActivity"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".TrueNewsActivity" android:exported="false"
            android:parentActivityName=".MainActivity"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".AiNewsSelectionActivity" android:exported="false"
            android:parentActivityName=".MainActivity"/>
        <activity android:name=".NewsDetectionActivity" android:exported="false"
            android:parentActivityName=".AiNewsSelectionActivity"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".ScanListActivity" android:exported="false"
            android:parentActivityName=".MainActivity"/>
        <activity android:name=".NetworkSecurityActivity" android:exported="false"
            android:parentActivityName=".MainActivity"/>
        <activity android:name=".SafeSearchActivity" android:exported="false"
            android:parentActivityName=".MainActivity"/>
        <activity android:name=".PanicModeActivity" android:exported="false"
            android:label="Emergency Shield"
            android:parentActivityName=".MainActivity"/>
        <activity android:name=".BatteryOptimizerActivity" android:exported="false"
            android:parentActivityName=".MainActivity"/>
        <activity android:name=".DataUsageActivity" android:exported="false"
            android:parentActivityName=".MainActivity"/>
        <activity android:name=".JunkCleanerActivity" android:exported="false"
            android:parentActivityName=".MainActivity"/>
        <activity android:name=".PrivacyAuditActivity" android:exported="false"
            android:parentActivityName=".MainActivity"/>

        <service android:name=".SafeSearchService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService"/>
            </intent-filter>
            <meta-data android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config"/>
        </service>

        <!-- Dynamic Control Bar Overlay Service -->
        <service
            android:name=".DynamicBarService"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <property android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Shows CyberRaksha Dynamic Control Bar overlay for security protection."/>
        </service>

        <service android:name=".CallDetectionService"
            android:foregroundServiceType="specialUse" android:exported="false">
            <property android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Identifies spam calls to protect users from fraud."/>
        </service>


        <!-- Island Notification Listener — intercepts ALL system notifications
             Enables: music, calls, messages, timers, any app → Dynamic Island
             User grants: Settings → Notification Access → CyberRaksha -->
        <service
            android:name=".IslandNotificationService"
            android:label="CyberRaksha Island Notifications"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>


        <!-- AppInstallReceiver — wires real PACKAGE_ADDED to BehaviorService
             This makes the Behavioral DNA Engine actually learn installed apps -->
        <receiver
            android:name=".AppInstallReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED"/>
                <data android:scheme="package"/>
            </intent-filter>
        </receiver>

    </application>
</manifest>
